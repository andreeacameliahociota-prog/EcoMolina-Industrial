<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos María Luisa - Molina de Segura</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .color-corporativo { background-color: #5d4037; } /* Marrón especia */
        .texto-especia { color: #5d4037; }
        .card-producto:hover { transform: translateY(-5px); transition: 0.3s; }
    </style>
</head>
<body class="bg-orange-50 font-sans">

    <header class="color-corporativo text-white p-6 shadow-xl sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-serif font-bold tracking-tight">PRODUCTOS MARÍA LUISA</h1>
                <p class="text-xs uppercase tracking-[0.2em] text-orange-200">Especias y Condimentos desde Molina</p>
            </div>
            <div class="text-right hidden md:block">
                <p class="text-sm font-bold">📍 Calle Estación / Menéndez Pelayo</p>
                <p class="text-xs opacity-80">Molina de Segura, Murcia</p>
            </div>
        </div>
    </header>

    <section class="bg-white py-12 border-b">
        <div class="container mx-auto px-6 text-center">
            <h2 class="text-4xl font-serif font-black texto-especia mb-4 italic">Haz tu pedido online y recógelo sin esperas</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Selecciona tus especias favoritas y envíanos el pedido directamente. Sin llamadas, a tu ritmo.</p>
        </div>
    </section>

    <main class="container mx-auto py-12 px-6 flex flex-col md:flex-row gap-8">
        
        <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-orange-100 card-producto">
                <div class="h-40 bg-orange-100 rounded-2xl mb-4 flex items-center justify-center text-5xl">🌿</div>
                <h3 class="font-bold text-xl mb-1">Pimentón de la Vera</h3>
                <p class="text-gray-500 text-sm mb-4">Aroma ahumado intenso, ideal para guisos.</p>
                <div class="flex justify-between items-center">
                    <span class="text-2xl font-black texto-especia">3,50€</span>
                    <button onclick="añadirAlCarrito('Pimentón de la Vera', 3.50)" class="color-corporativo text-white px-4 py-2 rounded-xl text-sm font-bold hover:opacity-90">Añadir</button>
                </div>
            </div>

            <div class="bg-white p-6 rounded-3xl shadow-sm border border-orange-100 card-producto">
                <div class="h-40 bg-orange-100 rounded-2xl mb-4 flex items-center justify-center text-5xl">🍯</div>
                <h3 class="font-bold text-xl mb-1">Azafrán en Hebra</h3>
                <p class="text-gray-500 text-sm mb-4">Calidad extra para tus arroces murcianos.</p>
                <div class="flex justify-between items-center">
                    <span class="text-2xl font-black texto-especia">5,20€</span>
                    <button onclick="añadirAlCarrito('Azafrán Hebra', 5.20)" class="color-corporativo text-white px-4 py-2 rounded-xl text-sm font-bold hover:opacity-90">Añadir</button>
                </div>
            </div>

            <div class="bg-white p-6 rounded-3xl shadow-sm border border-orange-100 card-producto">
                <div class="h-40 bg-orange-100 rounded-2xl mb-4 flex items-center justify-center text-5xl">🧂</div>
                <h3 class="font-bold text-xl mb-1">Pimienta Negra Molida</h3>
                <p class="text-gray-500 text-sm mb-4">Recién molida en nuestro almacén.</p>
                <div class="flex justify-between items-center">
                    <span class="text-2xl font-black texto-especia">2,80€</span>
                    <button onclick="añadirAlCarrito('Pimienta Negra', 2.80)" class="color-corporativo text-white px-4 py-2 rounded-xl text-sm font-bold hover:opacity-90">Añadir</button>
                </div>
            </div>

        </div>

        <aside class="w-full md:w-80 bg-white p-8 rounded-[2.5rem] shadow-2xl h-fit border-2 border-orange-100 sticky top-28">
            <h3 class="text-2xl font-black mb-6 texto-especia italic">Tu Pedido</h3>
            <div id="lista-carrito" class="space-y-4 mb-6 min-h-[100px] text-sm">
                <p class="text-gray-400 italic">El carrito está vacío...</p>
            </div>
            <div class="border-t pt-4">
                <div class="flex justify-between font-black text-xl mb-6">
                    <span>Total:</span>
                    <span id="total-precio">0.00€</span>
                </div>
                <button onclick="enviarWhatsApp()" class="w-full bg-green-600 text-white font-bold py-4 rounded-2xl shadow-lg hover:bg-green-700 transition flex items-center justify-center space-x-2">
                    <span>📱 Enviar por WhatsApp</span>
                </button>
                <p class="text-[10px] text-center text-gray-400 mt-4 uppercase font-bold tracking-widest">Se abrirá el chat de María Luisa</p>
            </div>
        </aside>

    </main>

    <script>
        let carrito = [];
        let total = 0;

        function añadirAlCarrito(nombre, precio) {
            carrito.push({nombre, precio});
            total += precio;
            actualizarInterfaz();
        }

        function actualizarInterfaz() {
            const lista = document.getElementById('lista-carrito');
            const totalTxt = document.getElementById('total-precio');
            
            if(carrito.length === 0) {
                lista.innerHTML = '<p class="text-gray-400 italic">El carrito está vacío...</p>';
            } else {
                lista.innerHTML = carrito.map((item, index) => `
                    <div class="flex justify-between items-center animate-fade-in">
                        <span class="font-medium">${item.nombre}</span>
                        <span class="font-bold">${item.precio.toFixed(2)}€</span>
                    </div>
                `).join('');
            }
            totalTxt.innerText = total.toFixed(2) + '€';
        }

        function enviarWhatsApp() {
            if(carrito.length === 0) return alert("Añade algún producto primero");
            
            let texto = "Hola Productos María Luisa, me gustaría hacer el siguiente pedido:\n\n";
            carrito.forEach(item => {
                texto += "- " + item.nombre + " (" + item.precio.toFixed(2) + "€)\n";
            });
            texto += "\n*Total: " + total.toFixed(2) + "€*";
            
            // Reemplaza con el número de teléfono del almacén
            const numero = "34664417137"; 
            const url = "https://wa.me/" + numero + "?text=" + encodeURIComponent(texto);
            window.open(url, '_blank');
        }
    </script>
</body>
</html>
